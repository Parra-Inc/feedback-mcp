# --------------------------------------------------------------------------
# Feedback MCP configuration
# Copy to .env (local dev) or set these on your host / in docker compose.
# --------------------------------------------------------------------------

# Database provider: "postgresql" (default) or "sqlite".
# (MongoDB is on the roadmap, blocked on a Prisma 7 driver adapter.)
DATABASE_PROVIDER=postgresql

# Connection string for the selected provider.
#   postgresql: postgresql://user:pass@host:5432/feedback
#   sqlite:     file:./data/feedback.db   (relative to apps/server)
# Defaults to the local dev Postgres from `pnpm up` when unset.
DATABASE_URL=postgresql://feedback:feedback@localhost:5452/feedback

# Secret for the MCP server and the admin read API. Required.
# Clients send it as `Authorization: Bearer <MCP_SECRET>`.
# Generate one with: openssl rand -hex 32
MCP_SECRET=

# Optional: cross-post every feedback submission to a Slack incoming webhook.
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Optional: ingest rate limits (requests per minute; 0 disables the check).
# The limiter is per instance; add a proxy-level limit for multi-replica setups.
# RATE_LIMIT_IP_PER_MINUTE=60
# RATE_LIMIT_PROJECT_PER_MINUTE=600

# Optional: auto-delete feedback older than this many days. Unset keeps
# everything forever. Swept at most hourly, piggybacking on ingest traffic.
# FEEDBACK_RETENTION_DAYS=365

# Optional: the public origin used in OAuth discovery metadata (for claude.ai
# connectors) when the app runs behind a proxy that rewrites Host headers.
# PUBLIC_URL=https://feedback.your-domain.com

# --------------------------------------------------------------------------
# Per-project secrets
# Project config (config/projects/<slug>/project.json) references env vars by
# name, so the secrets themselves live here, not in git.
# --------------------------------------------------------------------------

# Ingest key for the example project (config/projects/example-app).
# Client apps send it as the `X-Feedback-Key` header when submitting feedback.
# Generate one with: openssl rand -hex 32
EXAMPLE_APP_INGEST_KEY=

# Optional per-project Slack webhook override for the example project.
EXAMPLE_APP_SLACK_WEBHOOK=

# Optional: override where project/form config is read from.
# CONFIG_DIR=/path/to/config

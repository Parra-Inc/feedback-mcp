{
  "name": "feedback-mcp",
  "version": "0.2.0",
  "private": true,
  "description": "Free, open-source, self-hosted feedback collection with a built-in MCP server",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter @feedback-mcp/server dev",
    "dev:site": "pnpm --filter @feedback-mcp/site dev",
    "build": "pnpm -r build",
    "db:sync": "pnpm --filter @feedback-mcp/server db:sync",
    "up": "pnpm --filter @feedback-mcp/server up",
    "down": "pnpm --filter @feedback-mcp/server down"
  },
  "packageManager": "pnpm@9.15.9"
}

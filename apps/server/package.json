{
  "name": "@feedback-mcp/server",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3060",
    "build": "node scripts/prepare-prisma.mjs && prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "bash scripts/smoke.sh",
    "prisma:prepare": "node scripts/prepare-prisma.mjs",
    "db:sync": "node scripts/prepare-prisma.mjs && prisma format && prisma generate && prisma db push",
    "db:sync:force": "node scripts/prepare-prisma.mjs && prisma format && prisma generate && prisma db push --accept-data-loss",
    "db:migrate": "node scripts/prepare-prisma.mjs && prisma migrate dev",
    "db:deploy": "node scripts/prepare-prisma.mjs && prisma migrate deploy",
    "db:studio": "prisma studio --browser none --port 5560",
    "up": "docker compose up -d",
    "down": "docker compose down",
    "postinstall": "node scripts/prepare-prisma.mjs && prisma generate"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.3.1",
    "jose": "^6.2.2",
    "next": "16.2.1",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/pg": "^8",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
